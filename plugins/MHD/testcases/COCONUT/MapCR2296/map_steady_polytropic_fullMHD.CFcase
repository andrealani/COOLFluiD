#>>Full MHD# Mark 2024.05.21 try reducing Qh4H_const by say an order of magnitude, and start with a small CFL (by Michaela)
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qh4H_const = 4.0e-5 #it should be 4.0e-5
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qlio_AR = 5. #This is to control active region in Qhlio
#Tiko
#Simulator.SubSystemB.Flow.Data.MHDConsACAST.Qh4H_const = 2.e-5 #it should be 4.0e-5
#Simulator.SubSystemB.Flow.Data.MHDConsACAST.Qlio_AR = 7. #This is to control active region in Qhlio
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.P0_W=0.01
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.alfven_pressure = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.dpdxalfven = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qh2_activate = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qh3_activate = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qh4_activate = 1
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Qh_lio_activate = 0
#<<Full MHD#
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.divQ = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.divQConductivity = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.divQalphaCollisionless = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.ViscosityAndResistivity = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Viscosity = 0
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.Resistivity = 0
#>>Full MHD#
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.RadiativeLossTerm = 1
#<<Full MHD#
# Decomposed energy equation require "1"
Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.deCompEorNot = 1 # 0
# added on April 7, 2024 ?
#Simulator.SubSystemB.Flow.Data.MHDConsACAHWST.GravityPercentage= 1.0

# Boundary Conditions
#Simulator.SubSystemB.Flow.BcComds = SuperInletProjectionParallelRotationFVMCC SuperOutletMHD3DProjection9FVMCC
Simulator.SubSystemB.Flow.BcComds = SuperInletProjectionConstrainedFVMCC SuperOutletMHD3DProjection9FVMCC
#Simulator.SubSystemB.Flow.BcComds = SuperInletProjectionFVMCC SuperOutletMHD3DProjectionFVMCC
#Simulator.SubSystemB.Flow.BcComds = SuperInletProjectionParallelRotationFVMCC SuperOutletMHD3DProjectionFVMCC
Simulator.SubSystemB.Flow.BcNames = Jet1 Jet2

Simulator.SubSystemB.Flow.Jet1.applyTRS = Inlet
Simulator.SubSystemB.Flow.Jet1.Vars = x y z
Simulator.SubSystemB.Flow.Jet1.Def = \
	1. \
        (x*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        (y*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        (z*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        3*x*z \
        3*y*z \
        2*z^2-(x^2+y^2) \
        (2.0*1.67e-13*kB*1.5e6/(1.27*1.67e-27))/(2.2e-4^2./mu0) \
        0.

Simulator.SubSystemB.Flow.Jet1.InitialSolutionIDs = 4 5 6
Simulator.SubSystemB.Flow.Jet1.inletCoronalBC = 1
Simulator.SubSystemB.Flow.Jet1.Phi_divB_zero = 1
Simulator.SubSystemB.Flow.Jet1.Phi_divB_extrapolated = 0
Simulator.SubSystemB.Flow.Jet1.JensVelocityBC = 0
Simulator.SubSystemB.Flow.Jet1.BarbarasVelocityBC = 1
Simulator.SubSystemB.Flow.Jet1.hydrodynamic_limit = 0
Simulator.SubSystemB.Flow.Jet1.DanasVelocityBC = 0
Simulator.SubSystemB.Flow.Jet1.DifferentialRotation = 0
Simulator.SubSystemB.Flow.Jet1.JensBfieldBC = 0
Simulator.SubSystemB.Flow.Jet1.DanasBfieldBC = 0
Simulator.SubSystemB.Flow.Jet1.JonLinkersBfieldSuggestion = 1
Simulator.SubSystemB.Flow.Jet1.pressure_fixed = 1
Simulator.SubSystemB.Flow.Jet1.pressure_Neumann = 0
Simulator.SubSystemB.Flow.Jet1.JensRhoIni = 0
Simulator.SubSystemB.Flow.Jet1.JensPIni = 0
Simulator.SubSystemB.Flow.Jet1.VrBC = 1935.07 # in SI (m/s)
Simulator.SubSystemB.Flow.Jet1.PPorNot = true

# needed for computing Br from file
Simulator.SubSystemB.Flow.Jet1.VarIDs = 0
Simulator.SubSystemB.Flow.Data.NodalExtrapolation = DistanceBased
Simulator.SubSystemB.Flow.Data.DistanceBased.TRSName = Inlet
Simulator.SubSystemB.Flow.Data.DistanceBased.TemperatureID = 0
Simulator.SubSystemB.Flow.Data.DistanceBased.NbClosestPoints = 8

Simulator.SubSystemB.Flow.Jet2.applyTRS = Outlet
Simulator.SubSystemB.Flow.Jet2.refPhi = 0.

# Initial Conditions
Simulator.SubSystemB.Flow.InitComds = InitStateAddVar
Simulator.SubSystemB.Flow.InitNames = InField
Simulator.SubSystemB.Flow.InField.applyTRS = InnerFaces
Simulator.SubSystemB.Flow.InField.InitVars = x y z
Simulator.SubSystemB.Flow.InField.Vars = x y z r
Simulator.SubSystemB.Flow.InField.InitDef = sqrt(x^2+y^2+z^2)

# AL: this pre-processing command computes the coupling between EM and Flow solvers
# pre-processing to transfer solution of EM system to Flow by computing B field out of potential
# and filling corresponding "PreProcess1.VariableIDs" entries in the Flow equations

###############################################################################
###############################################################################
# EM solver
###############################################################################
###############################################################################

Simulator.SubSystemB.EM.Namespace = EMNamespace
Simulator.SubSystemB.EM.Data.CollaboratorNames = EMLSS EMIterator
Simulator.SubSystemB.EM.ComputeRHS = NumJacob
Simulator.SubSystemB.EM.SetNodalStatesCom = StdSetNodalStates
Simulator.SubSystemB.EM.StdSetNodalStates.updateGradients = true

Simulator.SubSystemB.EM.SetupCom = LeastSquareP1Setup
Simulator.SubSystemB.EM.SetupNames = Setup1
Simulator.SubSystemB.EM.Setup1.stencil = FaceVertexPlusGhost
Simulator.SubSystemB.EM.UnSetupCom = LeastSquareP1UnSetup
Simulator.SubSystemB.EM.UnSetupNames = UnSetup1

Simulator.SubSystemB.EM.Data.FluxSplitter = Null

Simulator.SubSystemB.EM.Data.UpdateVar  = Cons
Simulator.SubSystemB.EM.Data.SolutionVar = Cons
Simulator.SubSystemB.EM.Data.DiffusiveVar = Cons
Simulator.SubSystemB.EM.Data.DiffusiveFlux = PureDiffFlux

Simulator.SubSystemB.EM.Data.DerivativeStrategy = Corrected3D

Simulator.SubSystemB.EM.Data.PolyRec = LinearLS3D

Simulator.SubSystemB.EM.Data.NodalExtrapolation = DistanceBased
Simulator.SubSystemB.EM.Data.DistanceBased.TRSName = Inlet
Simulator.SubSystemB.EM.Data.DistanceBased.TemperatureID = 0
Simulator.SubSystemB.EM.Data.DistanceBased.NbClosestPoints = 8 #1 #2

Simulator.SubSystemB.EM.InitComds = InitState
Simulator.SubSystemB.EM.InitNames = InField
Simulator.SubSystemB.EM.InField.applyTRS = InnerFaces
Simulator.SubSystemB.EM.InField.Vars = x y z
Simulator.SubSystemB.EM.InField.Def = 0.

Simulator.SubSystemB.EM.BcComds = NeumannBCFromFileFVMCC SuperInletFVMCC
Simulator.SubSystemB.EM.BcNames = Inlet Outlet

Simulator.SubSystemB.EM.Inlet.applyTRS = Inlet
Simulator.SubSystemB.EM.Inlet.Vars = x y z
Simulator.SubSystemB.EM.Inlet.ZeroGradientFlags = 1

Simulator.SubSystemB.EM.Outlet.applyTRS = Outlet
Simulator.SubSystemB.EM.Outlet.Vars = x y z
Simulator.SubSystemB.EM.Outlet.Def = 0.0

Simulator.SubSystemB.DataPostProcessing = DataProcessing
Simulator.SubSystemB.DataPostProcessingNames = EMPostProcessing
Simulator.SubSystemB.EMPostProcessing.Comds = SphericalDerivatives
Simulator.SubSystemB.EMPostProcessing.Names = BrThetaPhi
Simulator.SubSystemB.EMPostProcessing.SkipFirstIteration = false # true
Simulator.SubSystemB.EMPostProcessing.ProcessRate = 1
Simulator.SubSystemB.EMPostProcessing.Namespace = EMNamespace
Simulator.SubSystemB.EMPostProcessing.Data.CollaboratorNames = EM


###>>Boundary conditions for simulations during March and July in 2024.
Simulator.SubSystemB.Flow.Jet1.rhoBC = 2.0  #1.0 #2.0 #20000.  #2.0 #1.0
Simulator.SubSystemB.Flow.Jet1.pBC = 0.25801090625  #0.00284615174  #0.08592156224 #0.108
Simulator.SubSystemB.Flow.InField.Def = \
if(r<22.000000000,2.0*((1/r)^5),2.*((1/22.0)^5)) \
1000/480363.085276*(-52.1+106*log(r+0.78))*(x/r) 1000/480363.085276*(-52.1+106*log(r+0.78))*(y/r) 1000/480363.085276*(-52.1+106*log(r+0.78))*(z/r) \
1. 2. 3. if(r<22.000000000,0.25801090625*((1/r)^5),0.25801090625*((1/22.0)^5)) 0.

