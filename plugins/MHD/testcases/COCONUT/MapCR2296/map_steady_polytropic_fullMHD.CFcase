Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.Manchester = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.ManchesterHeatingAmplitude = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.ManchesterSigma = 100.
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.divQ = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.divQConductivity = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.divQalphaCollisionless = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.ViscosityAndResistivity = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.Viscosity = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.Resistivity = 0
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.RadiativeLossTerm = 0
# Decomposed energy equation require "1"
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.deCompEorNot = 1 # 0
# added on April 7, 2024
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.GravityPercentage= 1.0

# Boundary Conditions
#Simulator.SubSystemA.Flow.BcComds = SuperInletProjectionFVMCC SuperOutletMHD3DProjectionFVMCC
#Simulator.SubSystemA.Flow.BcComds = SuperInletProjectionParallelRotationFVMCC SuperOutletMHD3DProjection9FVMCC
Simulator.SubSystemA.Flow.BcComds = SuperInletProjectionConstrainedFVMCC SuperOutletMHD3DProjection9FVMCC
Simulator.SubSystemA.Flow.BcNames = Jet1 Jet2

Simulator.SubSystemA.Flow.Jet1.applyTRS = Inlet
Simulator.SubSystemA.Flow.Jet1.Vars = x y z
Simulator.SubSystemA.Flow.Jet1.Def = \
	1. \
        (x*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        (y*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        (z*(-0.42108+26.794-628.89+6279.7+12899.60846+6026.2007+1445.2))/(2.2e-4/sqrt(mu0*1.67e-13)) \
        3*x*z \
        3*y*z \
        2*z^2-(x^2+y^2) \
        (2.0*1.67e-13*kB*1.5e6/(1.27*1.67e-27))/(2.2e-4^2./mu0) \
        0.	

Simulator.SubSystemA.Flow.Jet1.InitialSolutionIDs = 4 5 6
Simulator.SubSystemA.Flow.Jet1.inletCoronalBC = 1
Simulator.SubSystemA.Flow.Jet1.Phi_divB_zero = 1
Simulator.SubSystemA.Flow.Jet1.Phi_divB_extrapolated = 0
Simulator.SubSystemA.Flow.Jet1.JensVelocityBC = 0
Simulator.SubSystemA.Flow.Jet1.BarbarasVelocityBC = 1
Simulator.SubSystemA.Flow.Jet1.hydrodynamic_limit = 0
Simulator.SubSystemA.Flow.Jet1.DanasVelocityBC = 0
Simulator.SubSystemA.Flow.Jet1.DifferentialRotation = 0
Simulator.SubSystemA.Flow.Jet1.JensBfieldBC = 0
Simulator.SubSystemA.Flow.Jet1.DanasBfieldBC = 0
Simulator.SubSystemA.Flow.Jet1.JonLinkersBfieldSuggestion = 1
Simulator.SubSystemA.Flow.Jet1.pressure_fixed = 1
Simulator.SubSystemA.Flow.Jet1.pressure_Neumann = 0
Simulator.SubSystemA.Flow.Jet1.JensRhoIni = 0
Simulator.SubSystemA.Flow.Jet1.JensPIni = 0
Simulator.SubSystemA.Flow.Jet1.VrBC = 1935.07 # in SI (m/s)
Simulator.SubSystemA.Flow.Jet1.PPorNot = true

# needed for computing Br from file
Simulator.SubSystemA.Flow.Jet1.VarIDs = 0
