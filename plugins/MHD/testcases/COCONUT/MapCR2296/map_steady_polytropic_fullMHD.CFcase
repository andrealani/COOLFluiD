Simulator.SubSystemA.Flow.Data.UpdateVar  = PrimE
Simulator.SubSystemA.Flow.Data.SolutionVar = Cons
Simulator.SubSystemA.Flow.Data.LinearVar   = Cons
#Simulator.SubSystemA.Flow.Data.SourceTerm =  MHDConsACAST
Simulator.SubSystemA.Flow.Data.SourceTerm =  MHDConsACAHWST
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.CHIANTI9 = 1
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.gravity = 1
Simulator.SubSystemA.Flow.Data.MHDConsACAHWST.PevtsovHeating = 0
